  },
  "dependencies": {
    "goober": "^2.1.14",
    "preact": "^10.19.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.20.0"
  }
}
