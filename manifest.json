{
  "manifest_version": 3,
  "name": "Author's Companion",
  "version": "0.1.11",
  "description": "Calendar-based shoutout swap scheduler for Royal Road authors",
  "permissions": [
    "storage",
    "activeTab",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.royalroad.com/*",
    "https://rrwritersguild.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.royalroad.com/author-dashboard*",
        "https://www.royalroad.com/fiction/*/chapter/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://rrwritersguild.com/shoutouts/dashboard*"
      ],
      "js": ["dist/guild.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["guild.html", "dist/guild.js"],
      "matches": ["https://www.royalroad.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Author's Companion"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "192": "icons/rrlogo.png"
  }
}
